generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
enum Role { ADMIN LECTURER STUDENT RESEARCHER }
enum MaterialStatus { draft published archived }
model User { id String @id @default(uuid()) name String email String @unique passwordHash String role Role institution String? avatarUrl String? createdAt DateTime @default(now()) submissions Submission[] scores Score[] aiLogs AiLog[] certificates Certificate[] }
model Material { id String @id @default(uuid()) week Int title String level String status MaterialStatus @default(draft) skillMap Json outcomes Json listening Json reading Json speaking Json writing Json vocabulary Json quiz Json portfolio String? createdBy String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Assessment { id String @id @default(uuid()) title String type String level String indicators Json rubric Json items Json status String @default("active") createdBy String? createdAt DateTime @default(now()) }
model Submission { id String @id @default(uuid()) userId String user User @relation(fields:[userId], references:[id]) materialId String? assessmentId String? text String? evidenceUrl String? createdAt DateTime @default(now()) }
model Score { id String @id @default(uuid()) userId String user User @relation(fields:[userId], references:[id]) assessmentId String skill String score Float feedback String? scoredBy String createdAt DateTime @default(now()) }
model AiLog { id String @id @default(uuid()) userId String user User @relation(fields:[userId], references:[id]) tutor String message String response String createdAt DateTime @default(now()) }
model Room { id String @id @default(uuid()) title String meetingNo Int? level String? joinLink String? agenda Json breakouts Json notes String? createdBy String? createdAt DateTime @default(now()) }
model Attendance { id String @id @default(uuid()) roomId String userId String joinedAt DateTime @default(now()) leftAt DateTime? }
model Certificate { id String @id @default(uuid()) certificateNo String @unique userId String user User @relation(fields:[userId], references:[id]) title String score Float? cefrLevel String? qrUrl String? verifyUrl String? issuedBy String issuedAt DateTime @default(now()) }
model ResearchPassport { id String @id @default(uuid()) userId String preTest Json postTest Json evidence Json exports Json createdAt DateTime @default(now()) }
model ForumPost { id String @id @default(uuid()) userId String title String body String replies Json createdAt DateTime @default(now()) }
model HelpTicket { id String @id @default(uuid()) userId String category String message String status String @default("open") createdAt DateTime @default(now()) }
